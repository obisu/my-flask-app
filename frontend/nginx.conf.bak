server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Serve the React app
    location / {
        try_files $uri /index.html;
    }

    # Proxy API calls to the backend service
    location /api/ {
        proxy_pass http://flask-backend/api/;
    }
}

